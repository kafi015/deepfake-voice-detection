{"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"11ghgM46e-Y5J3fJ9wq7z8r1WyIEfKPMQ"},"executionInfo":{"elapsed":30286,"status":"ok","timestamp":1767012687118,"user":{"displayName":"Rubiat Jahan Momtahina","userId":"01179940852102660951"},"user_tz":-360},"id":"CtQ-VF33pPX0","outputId":"69c1d0df-d6d9-4faf-f11f-547976ad58f1"},"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}],"source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from scipy.io import wavfile\n","from scipy import signal\n","import io\n","import random\n","# Note: Loading data from Hugging Face Parquet requires the 'pyarrow', 'fsspec',\n","# and 'huggingface_hub' libraries to be installed in the environment.\n","\n","# --- 1. DATA LOADING (REAL DATA) ---\n","print(\"--- Loading Actual WaveFake Dataset from Hugging Face ---\")\n","try:\n","    # Load the Parquet file directly using the hf:// protocol\n","    df = pd.read_parquet(\"hf://datasets/ajaykarthick/wavefake-audio/data/partition0-00000-of-00001.parquet\")\n","\n","    # Define the unique labels dynamically from the loaded data\n","    unique_labels = sorted(df['real_or_fake'].unique().tolist())\n","\n","    # Ensure the 'audio' column contains dictionaries with bytes, as expected by the helper functions\n","    if not isinstance(df.iloc[0]['audio'], dict) or 'bytes' not in df.iloc[0]['audio']:\n","         print(\"Warning: 'audio' column format unexpected. EDA may fail if it's not dict with 'bytes'.\")\n","\n","except Exception as e:\n","    # Fallback simulation in case the environment cannot connect to Hugging Face or read the Parquet\n","    print(f\"\\n--- ERROR LOADING DATA: {e} ---\")\n","    print(\"--- FALLING BACK TO MOCK DATA SIMULATION ---\")\n","\n","    def create_mock_audio_bytes(duration_seconds=3, sample_rate=16000):\n","        num_samples = int(duration_seconds * sample_rate)\n","        audio_data = (np.random.normal(0, 1, num_samples) * 32767).astype(np.int16)\n","        buffer = io.BytesIO()\n","        wavfile.write(buffer, rate=sample_rate, data=audio_data)\n","        return {'bytes': buffer.getvalue()}\n","\n","    unique_labels = ['R', 'WF1', 'WF2', 'WF3', 'WF4', 'WF5', 'WF6', 'WF7']\n","    N_SAMPLES = 800\n","    data = {\n","        'audio_id': [f'LJ001-0001{label}{i}' for label in unique_labels for i in range(N_SAMPLES // 8)],\n","        'real_or_fake': [label for label in unique_labels for _ in range(N_SAMPLES // 8)],\n","    }\n","    df = pd.DataFrame(data)\n","    df['audio'] = df.apply(\n","        lambda row: create_mock_audio_bytes(duration_seconds=random.uniform(2.5, 4.5)),\n","        axis=1\n","    )\n","\n","print(f\"--- DataFrame Loaded successfully with {len(df)} samples ---\")\n","print(df.head(3))\n","print(\"-\" * 30)\n","\n","# --- 2. CORE HELPER FUNCTIONS ---\n","\n","def get_audio_info(audio_bytes_dict):\n","    \"\"\"Reads audio bytes from the structure and returns sample rate and data array.\"\"\"\n","    try:\n","        # The 'audio' column contains dictionaries: {'path': ..., 'bytes': ...}\n","        buffer = io.BytesIO(audio_bytes_dict['bytes'])\n","        sample_rate, data = wavfile.read(buffer)\n","        if data.ndim > 1:\n","            data = data[:, 0] # Convert stereo to mono\n","        return sample_rate, data\n","    except Exception as e:\n","        # Fallback for corrupted or unreadable data\n","        print(f\"Error reading audio: {e}\")\n","        return 0, np.array([])\n","\n","def get_audio_duration(audio_bytes_dict):\n","    \"\"\"Calculates the duration of the audio clip in seconds.\"\"\"\n","    sample_rate, data = get_audio_info(audio_bytes_dict)\n","    if sample_rate > 0 and len(data) > 0:\n","        return len(data) / sample_rate\n","    return 0\n","\n","# Calculate durations for basic EDA\n","# This step can take time on a large dataset as it processes all audio clips\n","print(\"\\n--- Calculating Audio Durations (This may take a moment) ---\")\n","df['duration_sec'] = df['audio'].apply(get_audio_duration)\n","print(\"--- Duration Calculation Complete ---\")\n","\n","\n","# --- 3. BASIC EDA: CLASS FREQUENCY AND DURATION ---\n","\n","def plot_class_frequency(df):\n","    \"\"\"Plots the frequency of each class in the 'real_or_fake' column.\"\"\"\n","    plt.figure(figsize=(10, 6))\n","    class_counts = df['real_or_fake'].value_counts(sort=False).sort_index()\n","    colors = plt.cm.viridis(np.linspace(0, 1, len(class_counts)))\n","    class_counts.plot(kind='bar', color=colors)\n","    plt.title('1. Class Frequency Distribution', fontsize=16)\n","    plt.xlabel('Audio Source (R=Real, WFx=DeepFake Generator)', fontsize=12)\n","    plt.ylabel('Number of Samples', fontsize=12)\n","    plt.xticks(rotation=0)\n","    plt.grid(axis='y', linestyle='--', alpha=0.7)\n","    plt.tight_layout()\n","    plt.show()\n","\n","def plot_duration_distribution(df):\n","    \"\"\"Plots the distribution of audio clip durations.\"\"\"\n","    plt.figure(figsize=(10, 6))\n","    df['duration_sec'].hist(bins=30, edgecolor='black', color='skyblue')\n","    plt.title('2. Audio Clip Duration Distribution', fontsize=16)\n","    plt.xlabel('Duration (Seconds)', fontsize=12)\n","    plt.ylabel('Frequency', fontsize=12)\n","    plt.axvline(df['duration_sec'].mean(), color='r', linestyle='dashed', linewidth=2, label=f\"Mean: {df['duration_sec'].mean():.2f}s\")\n","    plt.legend()\n","    plt.grid(axis='y', linestyle='--', alpha=0.7)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# --- 4. ADVANCED PER-CLASS ANALYSIS: WAVEFORM AND SPECTROGRAM ---\n","\n","def plot_per_class_visuals(df, n_samples=1):\n","    \"\"\"\n","    Plots the waveform and spectrogram for a single sample from each class.\n","\n","    FIXED: Changed pcolormesh shading from 'flat' to 'nearest' to resolve TypeError\n","    and updated colormap for attractive visuals.\n","    \"\"\"\n","\n","    # Use 'seaborn-v0_8-whitegrid' style for an attractive background\n","    plt.style.use('seaborn-v0_8-whitegrid')\n","\n","    fig, axes = plt.subplots(len(unique_labels), 2, figsize=(14, 4 * len(unique_labels)))\n","    fig.suptitle('3 & 4. Per-Class Waveforms and Spectrograms (Enhanced Visuals)', fontsize=20, y=0.99)\n","\n","    for i, label in enumerate(unique_labels):\n","        # 1. Get a sample\n","        sample_audio = df[df['real_or_fake'] == label].iloc[0]['audio']\n","        sample_rate, data = get_audio_info(sample_audio)\n","\n","        if sample_rate == 0 or len(data) == 0:\n","            axes[i, 0].set_title(f'[{label}] Data Error')\n","            axes[i, 1].set_title(f'[{label}] Data Error')\n","            continue\n","\n","        # Normalize time axis for plotting\n","        time = np.linspace(0, len(data) / sample_rate, num=len(data))\n","\n","        # --- Waveform Plot (Column 0) ---\n","        axes[i, 0].plot(time, data, color='#1f77b4', alpha=0.9, linewidth=0.5)\n","        axes[i, 0].set_title(f'[{label}] Waveform (Time Domain)', fontsize=14, fontweight='bold')\n","        axes[i, 0].set_xlabel('Time (s)')\n","        axes[i, 0].set_ylabel('Amplitude (Int16)')\n","        axes[i, 0].grid(linestyle=':', alpha=0.6)\n","\n","        # --- Spectrogram Plot (Column 1) ---\n","        # Calculate Spectrogram (STFT)\n","        # Using Hann window with 25ms window and 10ms hop (typical for speech)\n","        NFFT = int(0.025 * sample_rate)\n","        noverlap = int(0.010 * sample_rate)\n","\n","        # Ensure data length is sufficient\n","        if NFFT >= len(data): NFFT = len(data) // 2\n","        if noverlap >= NFFT: noverlap = NFFT // 2\n","\n","        if NFFT > 0:\n","            f, t, Sxx = signal.spectrogram(data, fs=sample_rate, window=signal.windows.hann(NFFT), nperseg=NFFT, noverlap=noverlap)\n","\n","            # Plot the log magnitude spectrogram\n","            # FIX: Use shading='nearest' to match scipy.signal.spectrogram output\n","            # Use 'plasma' for a vibrant, high-contrast visual (RGB effect)\n","            im = axes[i, 1].pcolormesh(t, f, 10 * np.log10(Sxx + 1e-6), shading='nearest', cmap='plasma')\n","\n","            axes[i, 1].set_title(f'[{label}] Spectrogram (Frequency Domain)', fontsize=14, fontweight='bold')\n","            axes[i, 1].set_xlabel('Time (s)')\n","            axes[i, 1].set_ylabel('Frequency (Hz)')\n","            axes[i, 1].set_ylim([0, sample_rate / 2])\n","\n","            # Add color bar for reference with enhanced label\n","            cbar = fig.colorbar(im, ax=axes[i, 1], orientation='vertical', fraction=0.046, pad=0.04)\n","            cbar.set_label('Log Power Density (dB)', fontsize=10)\n","        else:\n","            axes[i, 1].set_title(f'[{label}] Short Clip - Spectrogram Skipped')\n","\n","    plt.tight_layout(rect=[0, 0.03, 1, 0.98])\n","    plt.show()\n","    plt.style.use('default') # Reset style after function completion\n","\n","# --- 5. ADVANCED PAIRWISE ANALYSIS: MEAN SPECTRAL DENSITY ---\n","\n","def plot_mean_spectral_comparison(df):\n","    \"\"\"\n","    Calculates and plots the mean Power Spectral Density (PSD) for the Real class\n","    against each of the DeepFake classes to highlight frequency differences.\n","    \"\"\"\n","\n","    # Use 'seaborn-v0_8-whitegrid' style for an attractive background\n","    plt.style.use('seaborn-v0_8-whitegrid')\n","\n","    # Pre-calculate PSDs for all samples\n","    all_psds = []\n","\n","    # Limiting to 50 samples per class for demonstrative speed/stability\n","    df_subset = df.groupby('real_or_fake').head(50)\n","\n","    for _, row in df_subset.iterrows():\n","        sample_rate, data = get_audio_info(row['audio'])\n","\n","        # Calculate PSD using Welch's method (better for noisy signals)\n","        if len(data) > 1024 and sample_rate > 0:\n","            try:\n","                f, Pxx = signal.welch(data, fs=sample_rate, nperseg=1024)\n","                all_psds.append({'label': row['real_or_fake'], 'f': f, 'Pxx': Pxx})\n","            except ValueError:\n","                pass\n","\n","    if not all_psds:\n","        print(\"Could not calculate PSDs on subset. Skipping advanced comparison.\")\n","        return\n","\n","    psd_df = pd.DataFrame(all_psds)\n","\n","    # Group and calculate mean PSD\n","    mean_psds = {}\n","    for label in unique_labels:\n","        label_psds = psd_df[psd_df['label'] == label]['Pxx'].tolist()\n","        if label_psds:\n","            mean_psds[label] = np.mean(label_psds, axis=0)\n","\n","    if 'R' not in mean_psds:\n","        print(\"Real (R) samples required for baseline comparison are missing or failed PSD calculation.\")\n","        return\n","\n","    # Get the common frequency array\n","    f = psd_df.iloc[0]['f']\n","\n","    # Plotting\n","    plt.figure(figsize=(14, 8))\n","\n","    # Plot Real (R) PSD as the baseline\n","    plt.plot(f, 10 * np.log10(mean_psds.get('R', np.zeros_like(f)) + 1e-10),\n","             label='R (Real - Baseline)', color='black', linewidth=4, alpha=0.9, zorder=10)\n","\n","    # Plot differences for DeepFake generators\n","    colors = plt.cm.get_cmap('Spectral', len(unique_labels) - 1)\n","\n","    for i, label in enumerate([l for l in unique_labels if l != 'R']):\n","        if label in mean_psds:\n","            # Calculate the difference in dB (Log(WF) - Log(R))\n","            psd_diff = 10 * np.log10(mean_psds[label] + 1e-10) - 10 * np.log10(mean_psds.get('R', np.zeros_like(f)) + 1e-10)\n","\n","            # Plot the difference\n","            plt.plot(f, psd_diff, label=f'{label} Difference (vs R)', color=colors(i), linewidth=1.5, linestyle='-')\n","\n","\n","    plt.title('5. Advanced Pairwise Analysis: DeepFake Mean PSD Difference vs Real', fontsize=16, fontweight='bold')\n","    plt.xlabel('Frequency (Hz)', fontsize=12)\n","    plt.ylabel('Power Spectral Density Difference (dB)', fontsize=12)\n","    plt.grid(True, which=\"major\", linestyle='--', alpha=0.5)\n","    plt.legend(loc='upper right', bbox_to_anchor=(1.25, 1), fontsize=10, fancybox=True, shadow=True)\n","\n","    # Highlight the high-frequency area, where artifacts are often found\n","    plt.axvline(x=4000, color='red', linestyle=':', label='4 kHz marker (Artifact Zone)', linewidth=1)\n","\n","    plt.tight_layout()\n","    plt.show()\n","    plt.style.use('default') # Reset style after function completion\n","\n","\n","# --- 6. MAIN EXECUTION ---\n","if __name__ == '__main__':\n","\n","    # 1. Basic EDA\n","    print(\"\\n--- Running Basic EDA (Frequency & Duration) ---\")\n","    plot_class_frequency(df)\n","    plot_duration_distribution(df)\n","\n","    # 2. Advanced Per-Class Visualization\n","    print(\"\\n--- Running Per-Class Waveform and Spectrogram Analysis ---\")\n","    plot_per_class_visuals(df)\n","\n","    # 3. Advanced Pairwise Spectral Comparison\n","    print(\"\\n--- Running Advanced Pairwise Spectral Analysis (Subset Used) ---\")\n","    plot_mean_spectral_comparison(df)\n","\n","    print(\"\\n--- EDA Complete ---\")"]},{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1Gjfmw_OWF6l2eh1KxQsjbIukA1gqJVYl"},"executionInfo":{"elapsed":33341,"status":"ok","timestamp":1767012720510,"user":{"displayName":"Rubiat Jahan Momtahina","userId":"01179940852102660951"},"user_tz":-360},"id":"sEibZtIJtTmk","outputId":"0852be8b-5217-4104-b8e3-5734cb8fb8ce"},"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}],"source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from scipy.io import wavfile\n","from scipy import signal\n","from scipy.stats import gaussian_kde\n","import io\n","import random\n","# Note: Loadin